# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # never expose to browser

# ── Lemon Squeezy ─────────────────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=your-api-key
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# Product variant IDs — new plans 2026 (copy from LS dashboard → Products → Variants)
LS_VARIANT_STARTER_KIT=        # $27 one-time
LS_VARIANT_CORE_MONTHLY=       # $29/month
LS_VARIANT_CORE_ANNUAL=        # $199/year

# Legacy variant IDs (kept for backwards-compatibility with existing subscribers)
LS_VARIANT_14_DAYS=
LS_VARIANT_21_DAYS=
LS_VARIANT_45_DAYS=
LS_VARIANT_SUB_BASIC=
LS_VARIANT_SUB_PREMIUM=
LS_VARIANT_SUB_COMMUNITY=

# ── Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key

# ── Email & security secrets ──────────────────────────────────────────
# Random secret for signing unsubscribe/confirm tokens (min 32 chars)
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=generate-a-random-secret-here

# Secret for authenticating Vercel Cron requests (min 32 chars)
# Vercel sends this as: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
# Must also be set in Vercel Dashboard → Project Settings → Environment Variables
CRON_SECRET=generate-a-random-secret-here

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to https://insuliniq.com in production

# ── Tally (quiz embed) ────────────────────────────────────────────────
NEXT_PUBLIC_TALLY_FORM_ID=your-tally-form-id
